{
  "name": "solarxr-protocol",
  "version": "0.0.0",
  "description": "Serialization Protocol for SlimeVR",
  "main": "./protocol/typescript/dist/all.js",
  "types": "./protocol/typescript/dist/all.d.ts",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "tsc",
    "update-flatbuffers": "cd lib/flatbuffers && pnpm run compile",
    "prepare": "pnpm run update-flatbuffers && pnpm run build",
    "preinstall": "npx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SlimeVR/SolarXR-Protocol.git"
  },
  "author": "",
  "license": "(MIT OR Apache-2.0)",
  "bugs": {
    "url": "https://github.com/SlimeVR/SolarXR-Protocol/issues"
  },
  "homepage": "https://github.com/SlimeVR/SolarXR-Protocol#readme",
  "devDependencies": {
    "@mgit-at/typescript-flatbuffers-codegen": "^0.1.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "flatbuffers": "workspace:*"
  }
}
